generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum Side {
  MD
  DAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InvitationStatus {
  PENDING
  ACCEPTED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          UserRole @default(STUDENT)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  workspaces      Workspace[]
  transactions    Transaction[]
  exercises       Exercise[]
  submissions     Submission[]
  teacherClasses  Class[]        @relation("TeacherClasses")
  classMembers    ClassMember[]

  @@map("users")
}

model Account {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  type          AccountType
  normalBalance Side        @map("normal_balance")
  description   String?

  workspaceAccounts WorkspaceAccount[]
  entries           Entry[]
  openingBalances   OpeningBalance[]

  @@map("accounts")
}

model Workspace {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String
  exerciseId String?  @map("exercise_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise          Exercise?          @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  workspaceAccounts WorkspaceAccount[]
  transactions      Transaction[]
  submissions       Submission[]
  openingBalances   OpeningBalance[]

  @@map("workspaces")
}

model WorkspaceAccount {
  id          String @id @default(cuid())
  workspaceId String @map("workspace_id")
  accountId   String @map("account_id")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId])
  @@map("workspace_accounts")
}

model OpeningBalance {
  id          String  @id @default(cuid())
  workspaceId String  @map("workspace_id")
  accountId   String  @map("account_id")
  side        Side
  amount      Decimal @db.Decimal(15, 2)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId])
  @@map("opening_balances")
}

model Transaction {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  createdBy   String   @map("created_by")
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [createdBy], references: [id])
  entries   Entry[]

  @@map("transactions")
}

model Entry {
  id            String  @id @default(cuid())
  transactionId String  @map("transaction_id")
  accountId     String  @map("account_id")
  side          Side
  amount        Decimal @db.Decimal(15, 2)
  description   String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id])

  @@map("entries")
}

model Class {
  id        String   @id @default(cuid())
  name      String
  teacherId String   @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")

  teacher     User          @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  members     ClassMember[]
  invitations Invitation[]
  exercises   Exercise[]

  @@map("classes")
}

model ClassMember {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_members")
}

model Invitation {
  id      String           @id @default(cuid())
  classId String           @map("class_id")
  email   String
  token   String           @unique @default(cuid())
  status  InvitationStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Exercise {
  id          String     @id @default(cuid())
  createdBy   String     @map("created_by")
  classId     String?    @map("class_id")
  title       String
  description String
  difficulty  Difficulty @default(MEDIUM)
  createdAt   DateTime   @default(now()) @map("created_at")

  user                 User                  @relation(fields: [createdBy], references: [id])
  class                Class?                @relation(fields: [classId], references: [id], onDelete: SetNull)
  exerciseTransactions ExerciseTransaction[]
  submissions          Submission[]
  workspaces           Workspace[]

  @@map("exercises")
}

model ExerciseTransaction {
  id           String @id @default(cuid())
  exerciseId   String @map("exercise_id")
  expectedData Json   @map("expected_data")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_transactions")
}

model Submission {
  id          String   @id @default(cuid())
  exerciseId  String   @map("exercise_id")
  studentId   String   @map("student_id")
  workspaceId String   @map("workspace_id")
  score       Decimal? @db.Decimal(5, 2)
  isCorrect   Boolean? @map("is_correct")
  feedback    Json?
  submittedAt DateTime @default(now()) @map("submitted_at")

  exercise  Exercise  @relation(fields: [exerciseId], references: [id])
  student   User      @relation(fields: [studentId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("submissions")
}
